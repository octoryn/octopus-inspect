{
  "name": "octopus-inspect",
  "version": "0.3.1",
  "description": "Catch governance holes before production does. A static governance linter for AI agent workspaces.",
  "license": "Apache-2.0",
  "author": "Ran Tao <ran@octopusos.ai>",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octoryn/octopus-inspect.git"
  },
  "homepage": "https://github.com/octoryn/octopus-inspect#readme",
  "bugs": {
    "url": "https://github.com/octoryn/octopus-inspect/issues"
  },
  "keywords": [
    "linter",
    "governance",
    "static-analysis",
    "ai-agents",
    "secrets",
    "prompt-injection",
    "sarif",
    "mcp",
    "octopus",
    "octoryn"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "octopus-inspect": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CHANGELOG.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "coverage": "node --import tsx --test --experimental-test-coverage tests/*.test.ts",
    "example": "tsx examples/inspect-workspace.ts",
    "cli": "tsx src/cli.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run typecheck && npm run format:check && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  },
  "dependencies": {
    "octopus-evidence": "^0.2.0"
  }
}
